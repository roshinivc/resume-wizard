{
  "version": 2,
  "buildCommand": "npm run build",
  "outputDirectory": "dist/public",
  "rewrites": [
    { "source": "/api/:path*", "destination": "/api/:path*" },
    { "source": "/(.*)", "destination": "/index.html" }
  ],
  "functions": {
    "api/analyze.js": { "maxDuration": 30 },
    "api/corporate.js": { "maxDuration": 60 },
    "api/usage.js": { "maxDuration": 10 },
    "api/webhook.js": { "maxDuration": 10 },
    "api/auth.js": { "maxDuration": 10 },
    "api/feedback.js": { "maxDuration": 10 }
  }
}
